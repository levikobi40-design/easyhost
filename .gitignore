# ── Dependencies ────────────────────────────────────────────────────────────
node_modules/
node_modules
/.pnp
.pnp.js

# ── Local Python runtime (never commit the interpreter) ─────────────────────
python-3.11.9/
python-3*/
python-3*

# ── Build / cache output ─────────────────────────────────────────────────────
/build
/dist
/.cache
.cache/
node_modules/.cache/
*.pack
*.idx

# ── User-uploaded files (ephemeral — use Cloudinary in production) ────────────
uploads/

# ── Python compiled bytecode ─────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.pdb

# ── SQLite databases (dev only) ───────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Test coverage ─────────────────────────────────────────────────────────────
/coverage

# ── Secrets — NEVER commit ───────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Logs ─────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ── OS / editor artifacts ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?