# Hotel Dashboard - Environment Variables
# Copy to `.env` in this folder (never commit `.env`). Use this file as a template only.

# ============== API URL (single source of truth for frontend) ==============
# Production / Railway / Render: leave REACT_APP_API_URL unset (or set to '').
#   → all /api/... calls are relative (same origin as the page, no :1000 in production).
#
# Local dev: REACT_APP_API_URL is optional.
#   - Default (no env var): CRA proxy in package.json forwards /api/* to http://localhost:1000 automatically.
#   - Explicit override (LAN/phone/WSL): uncomment and set your machine IP below.
# REACT_APP_API_URL=http://localhost:1000
# REACT_APP_API_URL=http://192.168.1.175:1000

# ============== Dev server - access from phone on same network ==============
# HOST=0.0.0.0  # Uncomment to make React dev server reachable at your IP (e.g. http://192.168.1.x:3000)

# ============== GOOGLE AI (Gemini) - Maya AI ==============
# Get your API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here
# Optional: pin a model id (e.g. gemini-2.0-flash). Leave empty to auto-pick from ListModels (generateContent-capable).
# GEMINI_MODEL=
# GEMINI_MODEL_PRIMARY=   # optional alias, same precedence after GEMINI_MODEL
# MAYA_GEMINI_MODEL=      # optional legacy alias

# ============== Anthropic (Claude) - Maya AI (preferred when set) ==============
# https://console.anthropic.com/ — used when ANTHROPIC_API_KEY is set (see MAYA_BRAIN_PROVIDER)
ANTHROPIC_API_KEY=
# claude-3-5-sonnet-20241022 | claude-sonnet-4-20250514 | etc.
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# auto = use Claude if ANTHROPIC_API_KEY set, else Gemini | claude | gemini
MAYA_BRAIN_PROVIDER=auto

# ============== Real-world phone numbers (optional — no defaults in code) ==============
# Owner receives confirmations when staff clicks ראיתי
OWNER_PHONE=
# Staff receives task notifications with buttons
STAFF_PHONE=
# Optional JSON map for legacy name→phone hints, e.g. {"kobi":"+97252…","alma":"+97250…"}
# STAFF_PHONE_FALLBACK_JSON=

# ============== Twilio (optional - for SMS/WhatsApp) ==============
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# Default sender for WhatsApp/SMS when not passed per-message (sandbox or your Twilio number)
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# TWILIO_PHONE_FROM=+1234567890

# ============== Database (Supabase) — "could not translate host name" ==============
# Do NOT replace the hostname with a raw IP: PostgreSQL SSL expects the real hostname
# (certificate + Supabase routing). Prefer fixing DNS or switching connection type.
#
# 1) Supabase Dashboard → Project Settings → Database → copy the URI again (no typos).
# 2) Prefer "Session pooler" / port 6543 (host like …pooler.supabase.com) if direct db.* fails DNS.
# 3) On Windows: check VPN, corporate DNS, or set DNS to 8.8.8.8; then: ipconfig /flushdns
# 4) Optional: build URL from SUPABASE_URL + SUPABASE_DB_PASSWORD (see app.py _build_database_url)
#
# DATABASE_URL=postgresql://postgres:<DB_PASSWORD>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
#
# Optional: Session pooler (takes priority over DATABASE_URL when set). Copy from Supabase → Connection pooling.
# DATABASE_URL_POOLER=postgresql://postgres.<project-ref>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
#
# Backend timeouts (seconds unless noted). Tune if /api/properties still feels slow.
# DB_CONNECT_TIMEOUT_SEC=10
# DB_STATEMENT_TIMEOUT_MS=30000
# DB_POOL_TIMEOUT_SEC=15
# DB_QUERY_TIMEOUT_SEC=12

# ============== Auth / JWT (Flask) ==============
# When AUTH_DISABLED=false, the UI must send Authorization: Bearer <token> on protected routes.
# Generate a long random secret, e.g. openssl rand -hex 32
# JWT_SECRET=
# JWT_ISSUER=easyhost
# JWT_AUDIENCE=easyhost-dashboard
# JWT_EXP_HOURS=24
# AUTH_DISABLED=true
# ALLOW_DEMO_AUTH=true
# Optional bootstrap admin (Render / production)
# ADMIN_EMAIL=
# ADMIN_PASSWORD=

# Frontend: never put GEMINI_API_KEY or DATABASE passwords in REACT_APP_* — only public config.
# Run: npm run check:frontend-secrets

# ============== Staff role — default guest room slug for in-dashboard guest preview ==============
# REACT_APP_STAFF_GUEST_ROOM_SLUG=60

# ============== Security checklist (production) ==============
# - Set AUTH_DISABLED=false and JWT_SECRET to a long random value (openssl rand -hex 32).
# - Keep OpenAI/Gemini/Twilio/DB credentials only in server env or .env (not in source code).
# - Rotate keys if they ever appear in git history or logs.
# - Use HTTPS in production; never expose JWT in URL query strings in public pages.
