# ── React Frontend API URL ────────────────────────────────────────────────────
# Local dev  → http://localhost:1000   (Python backend must be running: python app.py)
# Production → set in render.yaml (https://easyhost.onrender.com)
REACT_APP_API_URL=http://localhost:1000

# ── Database — Supabase connection ────────────────────────────────────────────
# Fill in SUPABASE_URL and SUPABASE_KEY below (remove the # and replace the values).
# SQLite is disabled when these are set — the app will connect to Supabase only.
#
# SUPABASE_URL  → Supabase Dashboard → Project Settings → General → "Reference ID"
#                 Format: https://YOUR_PROJECT_REF.supabase.co
#
# SUPABASE_KEY  → Supabase Dashboard → Project Settings → API → "secret" key
#                 (the long key starting with sb_secret_ or eyJ...)
#
# ⬇️  Replace the placeholder values with your REAL Supabase credentials, then remove the # prefix
# SUPABASE_URL  → Supabase Dashboard → Project Settings → General → Reference ID
# SUPABASE_KEY  → Supabase Dashboard → Project Settings → API → service_role secret key
#
DATABASE_URL=postgresql://postgres:Tomakh10%21%40@db.birdalzsalkvjaghiauv.supabase.co:5432/postgres

# ── Google AI (Gemini) — Maya AI Assistant ────────────────────────────────────
