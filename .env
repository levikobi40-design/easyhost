# ── React Frontend API URL (local development) ───────────────────────────────
REACT_APP_API_URL=http://127.0.0.1:1000

# ── Database — Supabase connection ────────────────────────────────────────────
#
# There are THREE different Supabase credentials — make sure you use the right ones:
#
#  SUPABASE_URL         = your project URL  (Settings → General)
#                         Example: https://abcdefghij.supabase.co
#
#  SUPABASE_KEY         = service-role / SECRET key  (Settings → API → secret key)
#                         Starts with: eyJ...  OR  sb_secret_...
#                         ⚠️  This is for the REST API only — NOT a DB password
#
#  SUPABASE_DB_PASSWORD = your PostgreSQL DATABASE password  (Settings → Database)
#                         This is what SQLAlchemy uses to connect directly
#                         ⚠️  Different from SUPABASE_KEY — go to:
#                         Supabase → Project Settings → Database → Database Password
#                         (click "Reset" if you forgot it — you'll get a new one)
#
# Fill in all three below (remove the # prefix):
#SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
#SUPABASE_KEY=sb_secret_YOUR_SERVICE_ROLE_KEY
#SUPABASE_DB_PASSWORD=YOUR_DATABASE_PASSWORD
#
# — OR — set DATABASE_URL to the full connection string (alternative approach):
# Get it from: Supabase → Settings → Database → Connection string → URI
#DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

